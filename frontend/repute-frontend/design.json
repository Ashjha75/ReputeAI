--- START OF FILE design.json ---

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "ReputeAI Design System - Android / Google Aesthetic",
  "version": "2.1.0",
  "description": "Design system based on the Google/Android aesthetic: vibrant colors, airy spacing, large rounded corners, and bold typography. Built on Angular Material 3 and Tailwind CSS.",
  "lastUpdated": "2025-11-13",
  "framework": {
    "angular": "20.x",
    "material": "20.x (Material Design 3)",
    "tailwind": "4.x",
    "animations": "Angular Animations + Tailwind CSS"
  },
  "designPrinciples": {
    "googleAesthetic": "Clean, airy, bold typography, and large, soft rounded corners (rounded-3xl).",
    "responsiveFirst": "Mobile-first approach with generous, responsive spacing.",
    "materialFirst": "Always use Angular Material components (M3) as the foundation.",
    "accessible": "WCAG 2.1 AA compliant, emphasizing high color contrast.",
    "performance": "Optimized bundle size, lazy loading, and efficient rendering."
  },
  "colors": {
    "description": "Google-inspired color palette with Android Green as a key accent.",
    "primary": {
      "name": "Google Blue",
      "usage": "Main brand color, primary actions, links, active states.",
      "hex": "#1A73E8",
      "tailwind": {
        "50": "bg-blue-50 text-blue-50",
        "100": "bg-blue-100 text-blue-100",
        "200": "bg-blue-200 text-blue-200",
        "300": "bg-blue-300 text-blue-300",
        "400": "bg-blue-400 text-blue-400",
        "500": "bg-blue-500 text-blue-500",
        "600": "bg-blue-600 text-blue-600",
        "700": "bg-blue-700 text-blue-700",
        "800": "bg-blue-800 text-blue-800",
        "900": "bg-blue-900 text-blue-900"
      },
      "material": {
        "main": "var(--mat-primary-600)",
        "contrast": "var(--mat-primary-contrast)"
      }
    },
    "accent": {
      "name": "Android Green",
      "usage": "Success states, positive feedback, low-risk indicators, brand highlights (e.g., FAB).",
      "hex": "#3DDC84",
      "tailwind": "bg-[#3DDC84] text-[#3DDC84]",
      "material": {
        "main": "var(--mat-accent-500)",
        "contrast": "var(--mat-accent-contrast)"
      }
    },
    "surface": {
      "background": {
        "light": "#F8F9FA",
        "main": "#FFFFFF",
        "material": "var(--mat-sys-surface)",
        "tailwind": "bg-gray-50"
      },
      "card": {
        "elevated": "#FFFFFF",
        "material": "var(--mat-sys-surface-container)",
        "tailwind": "bg-white"
      }
    },
    "semantic": {
      "success": {
        "color": "#10B981",
        "background": "#D1FAE5",
        "tailwind": "text-emerald-600 bg-emerald-100",
        "usage": "Successful operations, low risk"
      },
      "warning": {
        "color": "#F59E0B",
        "background": "#FEF3C7",
        "tailwind": "text-amber-600 bg-amber-100",
        "usage": "Warnings, medium risk"
      },
      "error": {
        "color": "#EF4444",
        "background": "#FEE2E2",
        "tailwind": "text-red-600 bg-red-100",
        "usage": "Errors, critical issues, high risk"
      },
      "info": {
        "color": "#3B82F6",
        "background": "#DBEAFE",
        "tailwind": "text-blue-600 bg-blue-100",
        "usage": "Informational messages, tips"
      }
    },
    "text": {
      "primary": {
        "color": "#202124",
        "tailwind": "text-gray-900"
      },
      "secondary": {
        "color": "#5F6368",
        "tailwind": "text-gray-600"
      }
    }
  },
  "typography": {
    "description": "Roboto font family with a bold, hierarchical scale.",
    "fontFamily": {
      "primary": "'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "material": "var(--mat-sys-body-medium-font)"
    },
    "fontWeights": {
      "regular": 400,
      "medium": 500,
      "bold": 700
    },
    "scale": {
      "display": {
        "large": {
          "responsive": "text-5xl md:text-6xl lg:text-7xl font-bold",
          "material": "mat-display-large",
          "usage": "Hero sections (e.g., 'Android 14')"
        }
      },
      "headline": {
        "large": {
          "responsive": "text-3xl md:text-4xl lg:text-5xl font-bold",
          "material": "mat-headline-large",
          "usage": "Section titles (e.g., 'All the Latest')"
        }
      },
      "title": {
        "large": {
          "responsive": "text-xl md:text-2xl font-medium",
          "material": "mat-title-large",
          "usage": "Card titles, main navigation"
        }
      },
      "body": {
        "large": {
          "responsive": "text-base md:text-lg leading-relaxed",
          "material": "mat-body-large",
          "usage": "Main content, descriptive text"
        }
      },
      "label": {
        "medium": {
          "responsive": "text-sm font-medium tracking-wider uppercase",
          "material": "mat-label-medium",
          "usage": "Category tags, button text"
        }
      }
    }
  },
  "spacing": {
    "description": "Generous, airy spacing system (multiples of 8px).",
    "baseUnit": "0.25rem (4px)",
    "scale": {
      "8": "2rem (32px)",
      "12": "3rem (48px)",
      "16": "4rem (64px)",
      "20": "5rem (80px)"
    },
    "responsive": {
      "container": {
        "responsive": "px-4 py-8 md:px-8 md:py-12 lg:px-16 lg:py-20"
      },
      "section": {
        "responsive": "space-y-12 py-16 md:space-y-16 md:py-20 lg:space-y-24 lg:py-32"
      },
      "card": {
        "responsive": "p-6 space-y-4 md:p-8 lg:p-10"
      },
      "grid": {
        "responsive": "gap-4 md:gap-6 lg:gap-8"
      }
    }
  },
  "borderRadius": {
    "description": "Extremely rounded corners, a key Google aesthetic trait.",
    "scale": {
      "sm": "0.25rem",
      "md": "0.5rem",
      "lg": "0.75rem",
      "xl": "1rem",
      "2xl": "1.5rem",
      "3xl": "2rem",
      "full": "9999px"
    },
    "components": {
      "button": {
        "default": "rounded-lg",
        "pill": "rounded-full"
      },
      "card": {
        "responsive": "rounded-xl md:rounded-2xl lg:rounded-3xl"
      },
      "input": {
        "default": "rounded-xl"
      },
      "chip": "rounded-full"
    }
  },
  "shadows": {
    "description": "Subtle Material Design 3 elevation for a light, floating feel.",
    "material": {
      "level1": "var(--mat-sys-elevation-1)",
      "level2": "var(--mat-sys-elevation-2)"
    },
    "tailwind": {
      "default": "shadow-md",
      "hover": "shadow-lg",
      "2xl": "shadow-2xl"
    },
    "responsive": {
      "card": {
        "responsive": "shadow-md hover:shadow-lg transition-shadow duration-300"
      }
    }
  },
  "materialComponents": {
    "description": "Angular Material component usage with Google aesthetic styling.",
    "buttons": {
      "raised": {
        "component": "mat-raised-button",
        "responsive": {
          "desktop": "<button mat-raised-button color="primary" class="px-8 py-4 text-lg rounded-xl font-medium">Get Started</button>"
        },
        "animation": "hover:scale-105 active:scale-95 transition-all duration-200"
      },
      "fab": {
        "component": "mat-fab",
        "responsive": {
          "desktop": "<button mat-fab color="accent" class="rounded-full hover:shadow-xl"><mat-icon>add</mat-icon></button>"
        }
      }
    },
    "cards": {
      "basic": {
        "component": "mat-card",
        "responsive": {
          "desktop": "<mat-card class="shadow-lg hover:shadow-xl rounded-3xl transition-all duration-300">\n <mat-card-header class="space-y-4">\n <mat-card-title class="text-2xl font-bold">Title</mat-card-title>\n </mat-card-header>\n <mat-card-content class="pt-8 space-y-6">\n <p class="text-lg">Content</p>\n </mat-card-content>\n</mat-card>"
        },
        "animation": "@fadeIn + hover:shadow-2xl"
      }
    },
    "forms": {
      "textField": {
        "component": "mat-form-field",
        "appearance": "outline",
        "responsive": {
          "desktop": "<mat-form-field appearance="outline" class="w-full lg:w-1/2 rounded-xl">\n <mat-label>Email</mat-label>\n <input matInput type="email" required>\n <mat-icon matPrefix class="text-gray-400">email</mat-icon>\n</mat-form-field>"
        },
        "animation": "focus-within:scale-[1.01] transition-transform duration-200"
      }
    },
    "dataDisplay": {
      "chips": {
        "component": "mat-chip-set, mat-chip",
        "variants": {
          "categoryTag": "<mat-chip class="bg-blue-100 text-blue-600 rounded-lg text-sm font-medium uppercase tracking-wider">MESSAGES</mat-chip>"
        }
      }
    }
  },
  "responsiveLayouts": {
    "description": "Layout patterns for the airy, spaced-out Google aesthetic.",
    "listDetailLayout": {
      "desktop": "<!-- Desktop: Optimized split view with generous padding and rounded corners -->\n<div class="h-screen flex bg-gray-50">\n <!-- List (1/3) -->\n <div class="w-1/3 xl:w-1/4 bg-white border-r overflow-y-auto">\n <div class="p-8 border-b">\n <h2 class="text-2xl font-semibold">Content Library</h2>\n </div>\n <mat-list class="px-4 py-6">\n <mat-list-item class="h-32 hover:bg-blue-50 transition-all duration-300 rounded-2xl mb-4 p-4">\n <!-- Item with large image/icon, title, subtitle -->\n </mat-list-item>\n </mat-list>\n </div>\n \n <!-- Detail (2/3) -->\n <div class="flex-1 overflow-y-auto">\n <div class="p-16">\n <div class="max-w-4xl mx-auto">\n <mat-card class="p-12 shadow-xl rounded-3xl">\n <!-- Rich detail content -->\n </mat-card>\n </div>\n </div>\n </div>\n</div>"
    },
    "heroSection": {
      "responsive": "<div class="bg-white py-20 md:py-24 lg:py-32">\n <div class="max-w-7xl mx-auto px-4 md:px-8 lg:px-16">\n <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">Android: Write smarter, share quicker</h1>\n <p class="text-lg md:text-xl text-gray-600 max-w-4xl mb-10">The official source for news about Android.</p>\n <button mat-raised-button color="primary" class="px-10 py-5 text-xl rounded-xl font-medium shadow-lg hover:shadow-2xl">Discover</button>\n </div>\n</div>"
    }
  },
  "accessibility": {
    "description": "WCAG 2.1 AA compliance guidelines",
    "colorContrast": {
      "text": {
        "normal": "4.5:1 minimum ratio for body text",
        "large": "3:1 minimum for text >= 18pt or 14pt bold"
      }
    },
    "focusManagement": {
      "visible": "Always show focus indicators: focus:ring-2 focus:ring-primary focus:ring-offset-2"
    }
  },
  "riskLevelSystem": {
    "description": "ReputeAI-specific risk level visualization with Android Green and soft corners.",
    "levels": {
      "low": {
        "score": "0-49",
        "color": "#3DDC84",
        "tailwind": "text-[#3DDC84] bg-[#E8F8F0]",
        "icon": "check_circle",
        "badge": "<mat-chip class="bg-[#E8F8F0
        ] text-[#3DDC84
        ] rounded-lg">\n <mat-icon class="mr-1">check_circle</mat-icon>\n Low Risk\n</mat-chip>"
      },
      "medium": {
        "score": "50-69",
        "color": "#F59E0B",
        "tailwind": "text-amber-600 bg-amber-100",
        "icon": "warning",
        "badge": "<mat-chip class="bg-amber-100 text-amber-600 rounded-lg">\n <mat-icon class="mr-1">warning</mat-icon>\n Medium Risk\n</mat-chip>"
      },
      "high": {
        "score": "70-89",
        "color": "#F97316",
        "tailwind": "text-orange-600 bg-orange-100",
        "icon": "error",
        "badge": "<mat-chip class="bg-orange-100 text-orange-600 font-semibold rounded-lg">\n <mat-icon class="mr-1">error</mat-icon>\n High Risk\n</mat-chip>"
      },
      "critical": {
        "score": "90-100",
        "color": "#EF4444",
        "tailwind": "text-red-600 bg-red-100",
        "icon": "dangerous",
        "badge": "<mat-chip class="bg-red-100 text-red-600 font-bold border-2 border-red-300 rounded-xl">\n <mat-icon class="mr-1">dangerous</mat-icon>\n Critical Risk\n</mat-chip>"
      }
    }
  }
}
--- END OF FILE design.json ---